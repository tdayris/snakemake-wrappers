rule test_rbt_vcf_fix_iupac_alleles:
    input:
        "test.vcf",
    output:
        "fixed.bcf",
    threads: 2
    log:
        "logs/test_rbt_vcf_fix_iupac_alleles.log",
    wrapper:
        "master/bio/rbt/vcf_fix_iupac_alleles"


rule test_rbt_vcf_fix_iupac_alleles_io_formats:
    input:
        "fixed.bcf",
    output:
        "fixed.vcf.gz",
    threads: 2
    log:
        "logs/test_rbt_vcf_fix_iupac_alleles_io_formats.log",
    wrapper:
        "master/bio/rbt/vcf_fix_iupac_alleles"
