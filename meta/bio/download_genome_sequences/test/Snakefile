    species=r"saccharomyces_cerevisiae",
    build=r"R64-1-1",
    release=r"105",
    datatype=r"dna",


module download_genome_sequences:
    config:
        config
    meta_wrapper:
        "file:.."


use rule * from download_genome_sequences
